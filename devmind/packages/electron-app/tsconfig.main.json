{
    "compilerOptions": {
        "target": "ES6",
        "module": "CommonJS",
        "moduleResolution": "node",
        "outDir": "dist/main",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "baseUrl": ".",
        "paths": {
            "@devmind/cli-bridge": [
                "../cli-bridge/src/index"
            ],
            "@devmind/shared": [
                "../shared/src/index"
            ]
        }
    },
    "include": [
        "src/main"
    ],
    "references": [
        {
            "path": "../shared"
        },
        {
            "path": "../cli-bridge"
        }
    ]
}