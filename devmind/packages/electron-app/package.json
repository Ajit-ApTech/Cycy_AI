{
    "name": "@devmind/electron-app",
    "version": "1.0.0",
    "description": "Cycy AI Personal Assistant",
    "author": "Cycy Team",
    "main": "dist/main/main.js",
    "scripts": {
        "dev": "vite",
        "build:main": "tsc -p tsconfig.main.json",
        "build:preload": "esbuild src/main/preload.ts --bundle --platform=node --external:electron --outfile=dist/main/preload.js",
        "build:renderer": "vite build",
        "build": "npm run build:renderer && npm run build:main && npm run build:preload",
        "package": "npm run build && electron-builder --mac",
        "start": "electron ."
    },
    "dependencies": {
        "@devmind/cli-bridge": "*",
        "@devmind/shared": "*",
        "@monaco-editor/react": "^4.6.0",
        "@types/eslint": "^9.6.1",
        "axios": "^1.13.5",
        "better-sqlite3": "^11.5.0",
        "eslint": "^10.0.1",
        "lucide-react": "^0.300.0",
        "node-pty": "^1.0.0",
        "playwright": "^1.42.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "simple-git": "^3.32.1",
        "strip-ansi": "^6.0.1",
        "web-tree-sitter": "^0.26.5",
        "xterm": "^5.3.0",
        "xterm-addon-fit": "^0.8.0",
        "zustand": "^4.5.2"
    },
    "devDependencies": {
        "@electron/rebuild": "^4.0.3",
        "@types/better-sqlite3": "^7.6.13",
        "@types/node": "^20.0.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@vitejs/plugin-react": "^4.2.1",
        "electron": "^30.0.0",
        "electron-builder": "^24.13.3",
        "esbuild": "^0.21.5",
        "typescript": "^5.0.0",
        "vite": "^5.2.0"
    },
    "build": {
        "appId": "com.devmind.cycy",
        "productName": "Cycy",
        "electronVersion": "30.5.1",
        "files": [
            "dist/**/*",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "../../packages/spring-backend/build/libs",
                "to": "java-backend",
                "filter": [
                    "spring-backend-0.0.1-SNAPSHOT.jar"
                ]
            },
            {
                "from": "../../../dist-python",
                "to": "python-backend",
                "filter": [
                    "cycy-ai"
                ]
            }
        ],
        "mac": {
            "target": [
                "dmg"
            ],
            "hardenedRuntime": true,
            "gatekeeperAssess": false,
            "entitlements": "resources/entitlements.mac.plist"
        },
        "directories": {
            "output": "release"
        }
    }
}
